<Window x:Class="IP_Adress.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Width="500"
        Height="450"
        WindowStartupLocation="CenterOwner">

    <Border Background="#1E1E1E"
            CornerRadius="25"
            BorderBrush="#555"
            BorderThickness="2"
            SnapsToDevicePixels="True">

        <Grid Margin="20">

            <!-- Кнопка закрытия -->
            <Button Content="✕"
                    Width="40"
                    Height="40"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#333"
                    Foreground="White"
                    BorderBrush="#555"
                    FontSize="20"
                    Click="Close_Click"/>

            <!-- Текст -->
            <ScrollViewer Margin="0 50 0 0">
                <TextBlock TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="20"
                           TextAlignment="Center">
                    На IP адрес выделенно 4 байта.              <LineBreak/>
                         Из них выделенны под сеть:             <LineBreak/>
                             1 байт  - Класс А,                 <LineBreak/>
                             2 байта - Класс В,                 <LineBreak/>
                             3 байта - Класс С.                 <LineBreak/>
                    Из каждого байта выделенного под сеть       <LineBreak/>
                     один бит зарезервирован.Т.е в              <LineBreak/>
                    каждом байте не 8 бит, а 7.                 <LineBreak/>
                    Внимательнее с Классом А!!!                 <LineBreak/>
                    Это определяет количество возможных сетей.  <LineBreak/>
                    Оставшиеся байты остаются под хосты.        <LineBreak/>
                    Это и есть количество хостов и              <LineBreak/>
                     подключаемых устройств.                    <LineBreak/>
                    
                    
                </TextBlock>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>
