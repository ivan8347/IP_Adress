<Window x:Class="IP_Adress.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IP_Adress"
        Title="Классы IP-адресов"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="#121212"
        Foreground="White">

    <!-- РЕСУРСЫ ОКНА -->
   

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Классы IP-адресов (A, B, C)"
                   FontSize="32"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"/>

        <!-- Ввод IP -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0 0 0 10">
            <TextBox x:Name="IpInput"
                     Width="250"
                     Height="50"
                     FontSize="20"
                     Padding="10"
                     TextAlignment="Center"
                     Background="#1E1E1E"
                     BorderBrush="#444"
                     Foreground="White"/>

            <Button Content="Определить класс"
                    Height="50"
                    Margin="10 0 0 0"
                    Padding="10 5"
                    FontSize="16"
                    Background="#121212"
                    Foreground="White"
                    Click="CheckIpClass_Click"/>
        </StackPanel>

        <!-- Визуализация октетов -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 10">
            <Border x:Name="Oct1" Width="80" Height="50" CornerRadius="8" Margin="5" Background="#333">
                <TextBlock x:Name="Oct1Text" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
            </Border>
            <Border x:Name="Oct2" Width="80" Height="50" CornerRadius="8" Margin="5" Background="#333">
                <TextBlock x:Name="Oct2Text" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
            </Border>
            <Border x:Name="Oct3" Width="80" Height="50" CornerRadius="8" Margin="5" Background="#333">
                <TextBlock x:Name="Oct3Text" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
            </Border>
            <Border x:Name="Oct4" Width="80" Height="50" CornerRadius="8" Margin="5" Background="#333">
                <TextBlock x:Name="Oct4Text" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20"/>
            </Border>
        </StackPanel>

        <!-- Формула сверху -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0 0 50 10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="2^" FontSize="32" FontWeight="Bold"/>
                <TextBox x:Name="PowerInput"
                 Width="60"
                 FontSize="28"
                 Margin="10 0"
                 TextAlignment="Center"
                 Background="#1E1E1E"
                 Foreground="Gold"
                 BorderBrush="#555"
                 TextChanged="PowerInput_TextChanged"/>
                <TextBlock Text=" = " FontSize="32" FontWeight="Bold"/>
                <TextBlock x:Name="FormulaResult" FontSize="32" FontWeight="Bold" Foreground="LightGreen"/>
            </StackPanel>
        </StackPanel>


        <!-- Список классов -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ListBox x:Name="IpList"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding Color}"
                                CornerRadius="12"
                                Padding="24"
                                Margin="0 0 0 15">

                            <StackPanel>

                                <!-- Название -->
                                <TextBlock Text="{Binding Name}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Margin="0 0 0 0"
                                           TextAlignment="Center"/>

                                <!-- Описание -->
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="22" TextAlignment="Center"/>

                                <Grid Margin="0 20 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Диапазон -->
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                                        <TextBlock Text="Диапазон:" FontWeight="Bold" TextAlignment="Center"/>

                                        <TextBlock FontSize="26" TextAlignment="Left">
                                            <Run Text="{Binding FirstBits}" Foreground="Gold"/>
                                            <Run Text="{Binding OtherBits}" Foreground="White"/>
                                            <Run Text=" = "/>
                                            <Run Text="{Binding DecimalStart}" Foreground="LightGreen"/>
                                        </TextBlock>

                                        <TextBlock FontSize="26" TextAlignment="Left">
                                            <Run Text="{Binding FirstBitsEnd}" Foreground="Gold"/>
                                            <Run Text="{Binding OtherBitsEnd}" Foreground="White"/>
                                            <Run Text=" = "/>
                                            <Run Text="{Binding DecimalEnd}" Foreground="LightGreen"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Количество сетей -->
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Width="240">
                                        <TextBlock Text="Количество сетей:" FontWeight="Bold" TextAlignment="Center"/>

                                        <TextBox Text="{Binding Networks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="20"
                                              Margin="0 5"
                                              HorizontalContentAlignment="Center"
                                              Background="#1E1E1E"
                                              Foreground="{Binding NetworksColor}"
                                              BorderBrush="#555"/>

                                        <!--<Button Content="Информация"
                                                Margin="0 10 0 0"
                                                Width="150"
                                                Height="50"
                                                FontSize="18"
                                                Background="{Binding Color}"
                                                Foreground="Red"
                                                Click="Btn_Informacion_click"/>-->

                                        <!--<TextBlock Text="{Binding NetworksExplanation}"
                                             FontSize="14"
                                             TextWrapping="Wrap"
                                             Foreground="#CCCCCC"
                                             TextAlignment="Center"/>-->
                                    </StackPanel>

                                    <!-- Количество хостов -->
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Width="240">
                                        <TextBlock Text="Количество хостов:" FontWeight="Bold" TextAlignment="Center"/>

                                        <TextBox Text="{Binding Hosts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="20"
                                             Margin="0 5"
                                             HorizontalContentAlignment="Center"
                                             Background="#1E1E1E"
                                             Foreground="{Binding HostsColor}"
                                             BorderBrush="#555"/>

                                        <!--<TextBlock Text="{Binding HostsExplanation}"
                                            FontSize="14"
                                            TextWrapping="Wrap"
                                            Foreground="#CCCCCC"
                                            TextAlignment="Center"/>-->
                                         </StackPanel>

                                    <!-- Маска -->
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock Text="Маска:" FontWeight="Bold" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding MaskSlash}" Foreground="White" FontSize="20" TextAlignment="Left"/>
                                        <TextBlock Text="{Binding MaskDecimal}" Foreground="White" FontSize="20" TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                <Button         Width="60"
                                                    Height="60"
                                                    Background="{Binding Color}"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Click="InfoButton_Click">

                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>

                                                <!-- Круг -->
                                                <Ellipse x:Name="Circle"
                                                        Fill="{Binding Color}"
                                                        Stroke="Red"
                                                        StrokeThickness="5"/>

                                                <!-- Буква i -->
                                                <TextBlock Text="i"
                                                        FontSize="36"
                                                        FontWeight="Bold"
                                                        Foreground="White"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"/>
                                            </Grid>

                                            <!-- Убираем hover -->
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Circle" Property="Fill" Value="#1E1E1E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>
                                    </Button.Template>

                                </Button>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

    </Grid>
</Window>
